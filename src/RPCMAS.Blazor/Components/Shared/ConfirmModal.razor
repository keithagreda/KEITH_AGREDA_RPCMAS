@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">@ChildContent</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Cancel">@CancelText</button>
                    <button class="btn @ConfirmCss" @onclick="Confirm" disabled="@Busy">
                        @if (Busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @ConfirmText
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "Confirm";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string ConfirmText { get; set; } = "Confirm";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public string ConfirmCss { get; set; } = "btn-primary";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    public bool IsVisible { get; private set; }
    public bool Busy { get; private set; }

    public void Show() { IsVisible = true; Busy = false; StateHasChanged(); }
    public void Hide() { IsVisible = false; Busy = false; StateHasChanged(); }

    private async Task Confirm()
    {
        Busy = true;
        StateHasChanged();
        await OnConfirm.InvokeAsync();
        Busy = false;
    }

    private async Task Cancel()
    {
        IsVisible = false;
        await OnCancel.InvokeAsync();
    }
}
