@page "/requests/new"
@using RPCMAS.Blazor.Api
@using RPCMAS.Blazor.State
@using RPCMAS.Core.Enums
@inject ApiClient Api
@inject NotificationService Notifier
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>New Price Change Request</PageTitle>

<h2>New Price Change Request</h2>

<div class="row g-3 my-2">
    <div class="col-md-4">
        <label class="form-label">Department</label>
        <select class="form-select" value="@_dto.DepartmentId" @onchange="OnDepartmentChanged">
            <option value="0">-- Select --</option>
            @if (_depts is not null) { @foreach (var d in _depts) { <option value="@d.Id">@d.Name</option> } }
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Change Type</label>
        <select class="form-select" @bind="_dto.ChangeType">
            @foreach (var v in Enum.GetValues<ChangeType>()) { <option value="@v">@v</option> }
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Reason</label>
        <input class="form-control" @bind="_dto.Reason" />
    </div>
</div>

<h4 class="mt-4">Items</h4>

<div class="row g-2 mb-2">
    <div class="col-md-5">
        <input class="form-control" placeholder="Search SKU or name..." @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
    </div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100" @onclick="SearchItems">Search</button></div>
    <div class="col-md-2"><button class="btn btn-outline-secondary w-100" @onclick="ClearItemSearch">Clear</button></div>
</div>

@if (_itemsLoading)
{
    <p>Loading items...</p>
}
else if (_itemsPage is null || _itemsPage.Items.Count == 0)
{
    <div class="alert alert-light">No items.</div>
}
else
{
    <div class="border p-2 mb-2" style="max-height:320px; overflow-y:auto">
        @foreach (var i in _itemsPage.Items)
        {
            var alreadyAdded = _dto.Details.Any(d => d.ItemId == i.Id);
            <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                <div class="text-truncate me-2"><code>@i.Sku</code> — @i.Name (@i.Color @i.Size) — @i.CurrentPrice.ToString("N2")</div>
                <button class="btn btn-sm @(alreadyAdded ? "btn-secondary" : "btn-success")"
                        @onclick="() => AddItem(i)" disabled="@alreadyAdded">
                    @(alreadyAdded ? "Added" : "Add")
                </button>
            </div>
        }
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="text-muted small">Page @_itemsPage.Page of @_itemsPage.TotalPages — @_itemsPage.TotalCount items</span>
        <div>
            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="PrevItemPage" disabled="@(_itemsPage.Page <= 1)">Previous</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="NextItemPage" disabled="@(_itemsPage.Page >= _itemsPage.TotalPages)">Next</button>
        </div>
    </div>
}

@if (_dto.Details.Count == 0)
{
    <div class="alert alert-warning">Add at least one item.</div>
}
else
{
    <table class="table table-sm align-middle">
        <thead><tr>
            <th>SKU</th><th>Name</th><th class="text-end">Current</th>
            <th>Proposed</th><th class="text-end">Markdown%</th>
            <th>Effective</th><th>Remarks</th><th></th>
        </tr></thead>
        <tbody>
        @for (int idx = 0; idx < _dto.Details.Count; idx++)
        {
            var i = idx;
            var d = _dto.Details[i];
            <tr>
                <td><code>@d.Sku</code></td>
                <td>@d.ItemName</td>
                <td class="text-end">@d.CurrentPrice.ToString("N2")</td>
                <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="d.ProposedNewPrice" /></td>
                <td class="text-end">@d.MarkdownPercent.ToString("N2")</td>
                <td><input type="date" class="form-control form-control-sm" @bind="d.EffectiveDate" /></td>
                <td><input class="form-control form-control-sm" @bind="d.Remarks" /></td>
                <td><button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAt(i)">×</button></td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="d-flex gap-2 mt-3">
    <button class="btn btn-primary" @onclick="Save" disabled="@_busy">Save as Draft</button>
    <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("/requests")'>Cancel</button>
</div>

@code {
    private CreateRequestDto _dto = new() { ChangeType = ChangeType.Markdown };
    private List<DepartmentLookup>? _depts;
    private string? _search;
    private bool _busy;
    private bool _itemsLoading;
    private int _itemPage = 1;
    private const int ItemPageSize = 20;
    private PagedResponse<ItemDto>? _itemsPage;

    protected override async Task OnInitializedAsync()
    {
        try { _depts = await Api.GetDepartmentsAsync(); } catch { _depts = new(); }
        await LoadItems();
    }

    private async Task LoadItems()
    {
        _itemsLoading = true;
        try
        {
            int? dept = _dto.DepartmentId > 0 ? _dto.DepartmentId : null;
            _itemsPage = await Api.ListItemsAsync(_search, dept, _itemPage, ItemPageSize);
        }
        catch (ApiException ex) { Notifier.Error(ex.Message); }
        finally { _itemsLoading = false; }
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _itemPage = 1; await LoadItems(); }
    }

    private async Task SearchItems() { _itemPage = 1; await LoadItems(); }

    private async Task ClearItemSearch()
    {
        _search = null; _itemPage = 1;
        await LoadItems();
    }

    private async Task OnDepartmentChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _dto.DepartmentId = id;
            _itemPage = 1;
            await LoadItems();
        }
    }

    private async Task PrevItemPage() { if (_itemPage > 1) { _itemPage--; await LoadItems(); } }
    private async Task NextItemPage() { if (_itemsPage is not null && _itemPage < _itemsPage.TotalPages) { _itemPage++; await LoadItems(); } }

    private void AddItem(ItemDto i)
    {
        if (_dto.Details.Any(d => d.ItemId == i.Id)) return;
        _dto.Details.Add(new RequestDetailDto
        {
            ItemId = i.Id, Sku = i.Sku, ItemName = i.Name,
            CurrentPrice = i.CurrentPrice, ProposedNewPrice = i.CurrentPrice,
            EffectiveDate = DateTime.Today.AddDays(1)
        });
    }

    private void RemoveAt(int i) => _dto.Details.RemoveAt(i);

    private async Task Save()
    {
        if (_dto.DepartmentId == 0) { Notifier.Error("Select a department."); return; }
        if (_dto.Details.Count == 0) { Notifier.Error("Add at least one item."); return; }
        _busy = true;
        try
        {
            var created = await Api.CreateRequestAsync(_dto);
            if (created is not null)
            {
                Notifier.Success($"Created {created.RequestNumber}");
                Nav.NavigateTo($"/requests/{created.Id}");
            }
        }
        catch (ApiException ex) { Notifier.Error(ex.Message); }
        finally { _busy = false; }
    }
}
