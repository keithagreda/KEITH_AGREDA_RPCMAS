@page "/items/{Id:int}"
@using RPCMAS.Blazor.Api
@using RPCMAS.Blazor.State
@inject ApiClient Api
@inject NotificationService Notifier
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Item @(_item?.Sku ?? "")</PageTitle>

<button class="btn btn-link" @onclick='() => Nav.NavigateTo("/items")'>← Back</button>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_item is null)
{
    <div class="alert alert-warning">Item not found.</div>
}
else
{
    <h2>@_item.Name <small class="text-muted">(@_item.Sku)</small></h2>
    <dl class="row mt-3">
        <dt class="col-sm-3">Department</dt><dd class="col-sm-9">@_item.DepartmentName</dd>
        <dt class="col-sm-3">Category</dt><dd class="col-sm-9">@_item.Category</dd>
        <dt class="col-sm-3">Brand</dt><dd class="col-sm-9">@_item.Brand</dd>
        <dt class="col-sm-3">Variant</dt><dd class="col-sm-9">@_item.Color @_item.Size</dd>
        <dt class="col-sm-3">Current Price</dt><dd class="col-sm-9">@_item.CurrentPrice.ToString("N2")</dd>
        <dt class="col-sm-3">Cost</dt><dd class="col-sm-9">@_item.Cost.ToString("N2")</dd>
        <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@_item.Status</dd>
    </dl>
}

@code {
    [Parameter] public int Id { get; set; }
    private ItemDto? _item;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try { _item = await Api.GetItemAsync(Id); }
        catch (ApiException ex) { Notifier.Error(ex.Message); }
        finally { _loading = false; }
    }
}
